# Base URL of the gibl-api server, including the EFC route prefix (default "/api/v2").
EXPO_PUBLIC_API_URL=http://10.28.6.57:3002/api/v2

# SDK 57 made expo/fetch (no automatic cookie jar) the global `fetch`. Our session
# auth relies on an httpOnly cookie (efc_token) being stored and resent automatically,
# which only React Native's original fetch implementation does. Keep this on.
EXPO_PUBLIC_USE_RN_FETCH=1
